# Dépendances (réinstallées via bun install / npm install)
node_modules/

# Builds (régénérés via `ng build`, aucun binaire compilé à versionner)
dist/

# Logs de session locale
*.log

# Secrets (identifiants DB, jamais commités — voir .env.example pour la liste des clés attendues)
.env
.env.*
!.env.example

# Fichiers personnels apportés en cours de session (wishlist Excel), pas destinés à un dépôt distant
# même privé.
/data/

# Jaquettes locales : le catalogue réel utilise le hotlink LaunchBox CDN (import-launchbox-remote.ts),
# ce dossier est vide de facto pour les vraies données — régénérable via `bun run import:launchbox`
# si jamais utilisé. Les photos de consoles (apps/backend/public/consoles/), elles, RESTENT
# versionnées : Render (plan gratuit) n'a pas de stockage persistant, donc tout ce qui n'est ni en
# base ni dans l'image Docker disparaît au redéploiement — contrairement aux jaquettes, elles ne
# sont pas régénérables de façon fiable à la demande (rate-limiting Wikimedia rencontré cette session).
apps/backend/public/covers/

# Config locale de l'outillage agent (spécifique à cette machine)
/.claude/
