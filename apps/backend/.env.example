# Database — en local (Docker) : voir les valeurs dans project_setup, DB_SSL absent/false.
# En cloud (Supabase) : utiliser le connection pooling (Supavisor) plutôt que la connexion directe
# (db.<projet>.supabase.co) — le tier gratuit Supabase n'expose la connexion directe qu'en IPv6, pas
# joignable depuis la plupart des hébergeurs (dont Render). Host du pooler du style
# aws-<region>.pooler.supabase.com, port 5432 (mode session, adapté à un backend qui garde ses
# connexions ouvertes comme celui-ci — le port 6543/mode transaction cible plutôt du serverless),
# DB_USER au format postgres.<ref-projet>. Toutes ces valeurs sont dans Project Settings → Database
# du tableau de bord Supabase.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=collect_play_db
DB_USER=roydev
DB_PASSWORD=
DB_SSL=false

# Port d'écoute — laisser vide en local (retombe sur rdConfig.port, 6001). Les hébergeurs cloud
# (Render...) définissent PORT automatiquement, ne pas le fixer à la main dans ce cas.
PORT=
