{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ESNext",
        "rootDir": "./",
        "outDir": "dist/",
        "strict": true,
        "moduleResolution": "Bundler",
        "importHelpers": true,
        "experimentalDecorators": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "allowSyntheticDefaultImports": true,
        "resolveJsonModule": true,
        "forceConsistentCasingInFileNames": true,
        "removeComments": true,
        "typeRoots": [
            "node_modules/@types"
        ],
        "sourceMap": false,
        "baseUrl": "./",
        "paths": {
            "@utils/*": ["src/utils/*"],
            "@services/*": ["src/services/*"],
            "@routes/*": ["src/routes/*"],
            "@models/*": ["src/utils/interfaces/models/*"],
            "@queries/*": ["src/utils/queries/*"],
            "@middlewares/*": ["src/middlewares/*"]
        }
    },
    "include": [
        "src/server.ts",
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        ".vscode",
        ".git",
        ".env",
        "__tests__",
        "jest.config.js",
        "coverage"
    ]
}
